# hash256_miner.py — Fleet OS config
# Copy to .env and fill in values. NEVER commit .env.

# ── Required ───────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY    # Ethereum mainnet RPC
WALLET_FILE=./wallets.json                        # Fleet wallets (address + private_key)

# ── Single-wallet mode (alternative to WALLET_FILE) ───────────────────────────
# PRIVATE_KEY=0x...your_private_key              # Used only with --wallet flag

# ── Optional ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                    # DEBUG / INFO / WARNING
MAX_WORKERS=7                     # CPU workers for nonce grinding (default: cpu_count - 1)
GAS_PRICE_CAP=0                   # Max gas in gwei; 0 = no cap
PROXY_FILE=./proxies.json         # One proxy per wallet (optional)
